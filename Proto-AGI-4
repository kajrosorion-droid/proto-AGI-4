operator_scar = 0.0
operator_attention = None
proto_signals = np.zeros(NUM_SIGNALS)

def update_operator_scar(p):
    global operator_scar, operator_attention
    irreversible = p.crisis_memory * 0.5
    operator_scar = OPERATOR_MEMORY_DECAY * operator_scar + (1 - OPERATOR_MEMORY_DECAY) * irreversible
    for (x, y) in p.cells: operator_attention[x, y] += 0.1 * irreversible

def apply_operator_influence(field, patterns, t):
    global operator_scar, operator_attention, proto_signals
    field[:,:,CH['energy']] += OPERATOR_SCAR_IMPACT * operator_scar * operator_attention
    operator_attention *= 0.99

    avg_err = safe_mean([p.pred_error for p in patterns], 0.1) if patterns else 0.1
    avg_unk = safe_mean(field[:,:,CH['unknown']], 0.05)
    avg_soul = safe_mean([p.soul_weight for p in patterns], 0.5) if patterns else 0.5
    avg_bind = safe_mean(field[:,:,CH['binding']], 0.05)
    lineage_div = len(set(p.lineage_id for p in patterns)) if patterns else 0

    proto_signals[0] = 0.9 * proto_signals[0] + 0.1 * min(1.0, avg_err * 2)
    proto_signals[1] = 0.9 * proto_signals[1] + 0.1 * min(1.0, avg_unk * 3)
    proto_signals[2] = 0.9 * proto_signals[2] + 0.1 * min(1.0, avg_soul * 1.5)
    proto_signals[3] = 0.9 * proto_signals[3] + 0.1 * min(1.0, avg_bind * 4)
    proto_signals[4] = 0.9 * proto_signals[4] + 0.1 * min(1.0, lineage_div / 5.0)
    proto_signals[5] = 0.9 * proto_signals[5] + 0.1 * min(1.0, operator_scar * 50)

    for ch_idx, ch_name in enumerate(SIGNAL_NAMES):
        if proto_signals[ch_idx] < 0.05: continue
        candidates = np.argwhere(operator_attention > np.percentile(operator_attention, 95))
        if len(candidates) == 0: continue
        for _ in range(int(proto_signals[ch_idx] * 5)):
            cx, cy = candidates[int(phi_hash(t, ch_idx, _) * len(candidates)) % len(candidates)]
            field[cx, cy, CH['signal_' + ch_name]] = min(1.0,
                field[cx, cy, CH['signal_' + ch_name]] + OPERATOR_SIGNAL_STRENGTH * proto_signals[ch_idx])
    for ch in range(12, 18): field[:,:,ch] *= OPERATOR_SIGNAL_DECAY

def _process_death(field, p):
    for (x, y) in p.cells:
        field[x, y, CH['scar']] += 0.1 * max(p.compression, 0)
        field[x, y, CH['owner']] = 0
        field[x, y, CH['crisis']] += p.crisis_memory * 0.5
        field[x, y, CH['binding']] += p.unresolved_contradiction * 1.2
    store_echo(p)
    update_operator_scar(p)
    p.alive = False

