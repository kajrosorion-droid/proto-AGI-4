def _spawn_if_needed(field, patterns, next_id_counter, t, current_phase):
    if len(patterns) < 25:
        spawn_count = 5 if len(patterns) < 15 else 2
        for _ in range(spawn_count):
            x = int(phi_hash(t, _, 100) * WORLD_SIZE); y = int(phi_hash(t, _, 101) * WORLD_SIZE)
            if field[x, y, CH['owner']] == 0:
                pid = next_id_counter; next_id_counter += 1
                p = Pattern(pid, {(x, y)}); p.lineage_id = pid; patterns.append(p)
    return next_id_counter

def _resolve_competitions(field, patterns, current_phase):
    alive = [p for p in patterns if p.alive]
    for i, p1 in enumerate(alive):
        for p2 in alive[i+1:]:
            if p1.cells & p2.cells: p1.compete(p2, field, current_phase)

def _apply_divisions(field, patterns, next_id_counter):
    newborns = []
    for p in patterns:
        if p.can_divide():
            child = p.divide(field, next_id_counter)
            if child: newborns.append(child); next_id_counter += 1
    patterns.extend(newborns)
    return next_id_counter

def evolution_step(field, patterns, next_id_counter, t, global_hunger=1.0,
                   stabilization_active=False, recovery_active=False, crisis_level=0,
                   boredom_score=0.0, current_phase="MODEL"):
    next_id_counter = _spawn_if_needed(field, patterns, next_id_counter, t, current_phase)

    if len(patterns) > 40:
        patterns.sort(key=lambda p: p.fitness)
        for p in patterns[40:]: _process_death(field, p)
        patterns = [p for p in patterns if p.alive]

    lineage_counts = {}
    for p in patterns:
        lid = p.lineage_id; lineage_counts[lid] = lineage_counts.get(lid, 0) + 1
    if lineage_counts:
        dominant_lid = max(lineage_counts, key=lineage_counts.get)
        total = sum(lineage_counts.values())
        if lineage_counts[dominant_lid] > total * 0.6:
            for p in patterns:
                if p.lineage_id == dominant_lid:
                    p.genome['metabolic_cost'] = min(p.genome['metabolic_cost'] * (1.0 + LINEAGE_DOMINANCE_PENALTY), 0.15)

    center_x, center_y = WORLD_SIZE / 2.0, WORLD_SIZE / 2.0; center_radius = 20; center_count = 0
    for p in patterns:
        if not p.cells: continue
        xs = [c[0] for c in p.cells]; ys = [c[1] for c in p.cells]
        mx = np.mean(xs); my = np.mean(ys)
        if np.sqrt((mx - center_x)**2 + (my - center_y)**2) < center_radius: center_count += 1
    if center_count > 15:
        for p in patterns:
            if not p.cells: continue
            xs = [c[0] for c in p.cells]; ys = [c[1] for c in p.cells]
            mx = np.mean(xs); my = np.mean(ys)
            if np.sqrt((mx - center_x)**2 + (my - center_y)**2) < center_radius:
                p.genome['metabolic_cost'] = min(p.genome['metabolic_cost'] * 1.2, 0.2)

    if boredom_score > 0.4 and patterns:
        for p in patterns:
            if p.alive and phi_hash(p.id, t, 500) < 0.2: p.apply_given_operator(field, forced=True)

    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE):
            if (np.isfinite(field[x, y, CH['unknown']]) and field[x, y, CH['unknown']] > UNKNOWN_SPAWN_THRESHOLD and
                field[x, y, CH['owner']] == 0):
                if phi_hash(x, y, t) < UNKNOWN_SPAWN_PROB:
                    pid = next_id_counter; next_id_counter += 1; patterns.append(Pattern(pid, {(x, y)}))

    for p in patterns: p.update_model(field, current_phase, lineage_counts)
    for p in patterns: p.grow(field)
    _resolve_competitions(field, patterns, current_phase)
    next_id_counter = _apply_divisions(field, patterns, next_id_counter)

    for p in patterns:
