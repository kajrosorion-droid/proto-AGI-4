PHASES = ["EXPLORE", "MODEL", "COMPRESS", "CRISIS", "SILENCE", "BREAK"]

class PhaseController:
    def __init__(self):
        self.phase = "SILENCE"
        self.history = []
        self.last_scores = {p: 0.0 for p in PHASES}
        self.force_phase = None
        self.force_counter = 0

    def compute_scores(self, patterns, field, boredom, crisis_lvl):
        if len(patterns) == 0: return {p: 0.15 for p in PHASES}
        avg_tension = safe_mean([p.cognitive_tension for p in patterns], 0.1)
        avg_error = safe_mean([p.pred_error for p in patterns], 0.1)
        avg_unknown = safe_mean(field[:,:,CH['unknown']], 0.05)
        avg_surprise = safe_mean([p.self_surprise for p in patterns], 0.1)
        avg_crisis_mem = safe_mean([p.crisis_memory for p in patterns], 0.0)
        avg_soul_weight = safe_mean([p.soul_weight for p in patterns], 0.5)
        phase_noise = phi_hash(len(self.history), 0, 999) * 0.05
        cmem_factor = np.log1p(max(avg_crisis_mem, 0)) * 0.2
        model_score = ((1.0 - avg_error) * 1.2 + 0.8 * (1.0 - boredom) +
                       0.3 * (1.0 - avg_tension) - 0.5 * avg_tension -
                       0.5 * avg_surprise - 0.5 * avg_unknown + 0.3 * (1.0 - avg_unknown))
        model_stability_penalty = np.tanh(len(self.history) / 50) * 0.15
        model_score -= model_stability_penalty + phase_noise * 0.5
        scores = {
            "EXPLORE": 0.4 * avg_unknown + 0.4 * boredom + 0.3 * avg_surprise + 0.2 * cmem_factor + phase_noise,
            "MODEL": model_score,
            "COMPRESS": (1.0 - avg_tension) * 1.0 + 0.6 * (1.0 - avg_unknown) +
                       0.6 * max(0, 1.0 - avg_error * 10) * (1.0 - boredom) + phase_noise * 0.3,
            "CRISIS": crisis_lvl * 2.0 + avg_tension * 0.2 + avg_surprise * 0.2 + cmem_factor * 0.2 + phase_noise * 0.2,
            "SILENCE": boredom * 1.2 + (1.0 - avg_error) * 0.8 + avg_tension * 0.5 + phase_noise * 0.2 +
                       0.5 * (1.0 - avg_soul_weight),
            "BREAK": avg_surprise * 1.5 + avg_tension * 1.2 + boredom * 0.8 + (1.0 - avg_error) * 0.5 +
                     cmem_factor * 0.3 - 0.7 * avg_error + phase_noise * 0.4
        }
        recent = self.history[-50:] if len(self.history) >= 50 else self.history
        for p in PHASES:
            if recent.count(p) < 2: scores[p] *= 1.25
        if len(self.history) > 50 and self.history[-50:].count("MODEL") > 45:
            scores["EXPLORE"] *= 1.5; scores["CRISIS"] *= 1.3
        if crisis_lvl == 0 and avg_tension < 0.01: scores["CRISIS"] *= 0.2
        if avg_soul_weight < 0.2: scores["CRISIS"] *= 1.5; scores["EXPLORE"] *= 1.3
        total = sum(scores.values()) + 1e-9
        for k in scores: scores[k] /= total
        return scores

    def update(self, patterns, field, boredom, crisis_lvl):
        if patterns:
            avg_tension = safe_mean([p.cognitive_tension for p in patterns], 0.1)
            avg_error = safe_mean([p.pred_error for p in patterns], 0.1)
            avg_surprise = safe_mean([p.self_surprise for p in patterns], 0.1)
            stable_signal = squash(avg_error) + squash(avg_tension) + squash(avg_surprise)
            if stable_signal > 1.5:
                for p in patterns:
                    p.self_surprise = max(p.self_surprise * 0.5, MIN_ACTIVE)
                    p.pred_error = max(p.pred_error * 0.5, MIN_ACTIVE)
                self.force_phase = "SILENCE"; self.force_counter = 3
                self.phase = "SILENCE"; self.history.append(self.phase)
                return self.phase
        if self.force_counter > 0:
            self.force_counter -= 1
            if self.force_counter == 0: self.force_phase = None
            self.phase = self.force_phase if self.force_phase else "MODEL"
            self.history.append(self.phase); return self.phase
        raw_scores = self.compute_scores(patterns, field, boredom, crisis_lvl)
        for k in raw_scores:
            if k == self.phase: raw_scores[k] *= (1.0 + PHASE_HYSTERESIS)
        if self.phase == "CRISIS" and crisis_lvl == 0: raw_scores["CRISIS"] *= 0.3
        if self.phase == "MODEL" and len(self.history) > 30:
            if self.history[-30:].count("MODEL") > 25: raw_scores["BREAK"] *= 1.5
        if len(self.history) >= PHASE_LOCK_WINDOW:
            if self.history[-PHASE_LOCK_WINDOW:].count(self.phase) >= PHASE_LOCK_THRESHOLD:
                raw_scores[self.phase] *= PHASE_LOCK_PENALTY
        self.last_scores = raw_scores.copy()
        self.phase = max(raw_scores, key=raw_scores.get)
        self.history.append(self.phase)
        if self.phase == "BREAK": self.force_phase = "MODEL"; self.force_counter = RECOVERY_WINDOW
        return self.phase

