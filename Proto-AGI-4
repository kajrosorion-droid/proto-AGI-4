        self.belief = np.zeros(5); self.prediction = np.zeros(5); self.model = np.zeros(5)
        self.self_state_prediction = np.array([0.0, 0.0])
        self.self_model = np.array([0.1, 0.1]); self.self_surprise = MIN_ACTIVE
        self._prev_energy = 0.0
        self.spirit_gap = 0.0; self.soul_weight = 0.5; self.soul_momentum = 0.0
        self.body_memory = 0.0; self.unresolved_contradiction = 0.1
        if parent: flip = 1 if phi_hash(pid, 888, 0) < 0.2 else 0; self.role = (parent.role + flip) % 2
        else: self.role = 0 if phi_hash(pid, 777, 0) < 0.5 else 1
        self.unknown_belief = 0.0; self.unknown_model = 0.0; self.unknown_prediction = 0.0
        self.epistemic_load = 0.0; self.prev_epistemic_load = 0.0
        self.crisis_memory = min(parent.crisis_memory * 0.8, CRISIS_MEMORY_MAX) if parent else 0.0
